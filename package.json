{
  "name": "jigsaw",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "verify:packages": "npm run build --workspace=@jigsaw-ds/design-system --workspace=@jigsaw-ds/tokens --workspace=@jigsaw-ds/theme-default --workspace=@jigsaw-ds/theme-portfolio && node scripts/verify-publishable-packages.mjs",
    "validate:packages": "npm run verify:packages && node scripts/validate-publishable-packages.mjs"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@changesets/cli": "^2.31.0",
    "prettier": "^3.2.5",
    "publint": "^0.3.21",
    "turbo": "^2.3.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/themes/*"
  ],
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.19.0"
  }
}
