{
  "name": "@jigsaw-ds/tokens",
  "version": "0.1.0",
  "description": "Design tokens and Tailwind CSS v4 theme (CSS variables) for the Jigsaw design system.",
  "license": "MIT",
  "author": "James Howell",
  "homepage": "https://github.com/decodedcreative/jigsaw/tree/main/packages/tokens#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/decodedcreative/jigsaw.git",
    "directory": "packages/tokens"
  },
  "bugs": {
    "url": "https://github.com/decodedcreative/jigsaw/issues"
  },
  "keywords": [
    "design-tokens",
    "tailwindcss",
    "css-variables",
    "style-dictionary"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./shared/*": "./dist/css/shared/*",
    "./tailwind-theme.css": "./dist/css/tailwind-theme.css",
    "./docs-tokens": {
      "types": "./docs-tokens.d.ts",
      "import": "./dist/docs-tokens.mjs"
    },
    "./css-color": {
      "types": "./dist/css-color.d.ts",
      "import": "./dist/css-color.mjs",
      "require": "./dist/css-color.js"
    }
  },
  "files": [
    "dist",
    "docs-tokens.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run clean && npm run build:tokens && tsup",
    "build:tokens": "node scripts/build-tokens.mjs",
    "verify:figma-tokens": "node scripts/verify-figma-tokens.mjs",
    "check:figma-drift": "node scripts/check-figma-drift.mjs",
    "test": "npm run build:tokens && vitest run",
    "test:watch": "vitest",
    "dev": "npm run build:tokens && tsup --watch",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@jigsaw-ds/theme-build": "^0.1.0",
    "eslint": "^9.16.0",
    "globals": "^14.0.0",
    "style-dictionary": "^4.1.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.8"
  }
}
