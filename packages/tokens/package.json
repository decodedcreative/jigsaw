{
  "name": "@jigsaw/tokens",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./shared/*": "./dist/css/shared/*",
    "./themes/*": "./dist/css/themes/*",
    "./theme": "./dist/theme.mjs",
    "./semantic-colors": {
      "types": "./dist/semantic-colors.d.ts",
      "import": "./dist/semantic-colors.mjs",
      "require": "./dist/semantic-colors.js"
    }
  },
  "scripts": {
    "build": "npm run build:tokens && tsup",
    "build:tokens": "node scripts/build-tokens.mjs",
    "verify:figma-tokens": "node scripts/verify-figma-tokens.mjs",
    "check:figma-drift": "node scripts/check-figma-drift.mjs",
    "test": "npm run build:tokens && vitest run",
    "test:watch": "vitest",
    "dev": "npm run build:tokens && tsup --watch",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@jigsaw/theme-build": "*",
    "eslint": "^9.16.0",
    "globals": "^14.0.0",
    "style-dictionary": "^4.1.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.8"
  }
}
