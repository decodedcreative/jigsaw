{
  "name": "@jigsaw-ds/design-system",
  "version": "0.1.0",
  "description": "React component library for the Jigsaw design system, built on React Aria Components and Tailwind CSS v4.",
  "license": "MIT",
  "author": "James Howell",
  "homepage": "https://github.com/decodedcreative/jigsaw/tree/main/packages/design-system#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/decodedcreative/jigsaw.git",
    "directory": "packages/design-system"
  },
  "bugs": {
    "url": "https://github.com/decodedcreative/jigsaw/issues"
  },
  "keywords": [
    "design-system",
    "react",
    "components",
    "react-aria",
    "tailwindcss",
    "ui"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tailwind.css": "./tailwind.css"
  },
  "files": [
    "dist",
    "tailwind.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@jigsaw-ds/tokens": "^0.1.0",
    "@phosphor-icons/react": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "react-aria-components": "^1.17.0",
    "tailwind-merge": "^2.5.5"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@storybook/react": "10.2.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.16.0",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.6"
  }
}
